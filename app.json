{
    "expo":  {
                 "name":  "Darkor.ai",
                 "slug":  "darkor-ai",
                 "scheme":  "darkorai",
                 "version":  "1.0.0",
                 "orientation":  "portrait",
                 "userInterfaceStyle":  "dark",
                 "platforms":  [
                                   "ios",
                                   "android"
                               ],
                 "ios":  {
                             "supportsTablet":  true,
                             "bundleIdentifier":  "com.darkor.ai"
                         },
                 "android":  {
                                 "package":  "com.darkor.ai"
                             },
                 "plugins":  [
                                 "expo-router",
                                 "expo-secure-store",
                                 [
                                     "expo-image-picker",
                                     {
                                         "photosPermission":  "Darkor.ai needs access to your photos so you can upload room images.",
                                         "cameraPermission":  "Darkor.ai needs camera access so you can capture a room before redesign."
                                     }
                                 ]
                             ],
                 "experiments":  {
                                     "typedRoutes":  true
                                 }
             }
}
