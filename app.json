{
  "expo": {
    "name": "HomeDecor AI",
    "slug": "homedecor-ai",
    "scheme": "homedecorai",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "backgroundColor": "#FFFFFF",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "androidStatusBar": {
      "backgroundColor": "#FFFFFF",
      "barStyle": "dark-content",
      "translucent": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#FFFFFF",
      "barStyle": "dark-content",
      "enforceContrast": false
    },
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.homedecor.ai",
      "icon": "./assets/app-icon.png"
    },
    "android": {
      "package": "com.ismail.homedecorai",
      "versionCode": 30,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-router",
      "@clerk/expo",
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/Fonts/InterVariable.ttf"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "We need photo access so you can upload room images for AI redesigns.",
          "cameraPermission": "We need camera access so you can snap a photo of your room to redesign it."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "We need photo library access so you can save your redesigned images to your device."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      "./plugins/with-kotlin-resolution",
      "expo-image",
      "expo-localization",
      "expo-sharing",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": "1.0.4",
    "updates": {
      "enabled": false,
      "url": "https://u.expo.dev/c18000f7-d1c7-461d-b1eb-66d713f40cf4",
      "checkAutomatically": "ON_ERROR_RECOVERY"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c18000f7-d1c7-461d-b1eb-66d713f40cf4"
      }
    },
    "owner": "ismail-app",
    "userInterfaceStyle": "light"
  }
}
